region        = "us-west-2"
cluster_name  = "aiops-test-cluster"
environment   = "dev"

cluster_version     = "1.30"
node_instance_types = ["m5.large"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 4

# --- Networking ---
# Option A: Create a new VPC (leave vpc_id and private_subnet_ids unset)
vpc_cidr = "10.0.0.0/16"

# Option B: Use an existing VPC (set both vpc_id and private_subnet_ids)
# vpc_id             = "vpc-0abc123def456789"
# private_subnet_ids = ["subnet-0aaa111", "subnet-0bbb222", "subnet-0ccc333"]

# Observability
enable_container_insights     = true
cloudwatch_log_retention_days = 14

# Optional - set to true to install Prometheus/Grafana
enable_prometheus = false
enable_grafana    = false

tags = {
  Project     = "aiops-agents"
  Environment = "test"
  ManagedBy   = "terraform"
}
